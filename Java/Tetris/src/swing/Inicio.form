<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="swing.Inicio">
  <grid id="27dc6" binding="panel_inicio" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="7337e" binding="panel_registro" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="Center"/>
        <properties>
          <background color="-13622257"/>
        </properties>
        <border type="none"/>
        <children/>
      </grid>
      <grid id="98fb9" binding="panel_cabecera" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints border-constraint="North"/>
        <properties>
          <background color="-13630428"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="e59cd" class="javax.swing.JLabel" binding="label_titulo">
            <constraints/>
            <properties>
              <text value="Tetris"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
